# =============================================================================
# Marine Intelligence Platform (DockGuard) -- Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.

# -- Database -----------------------------------------------------------------
# PostgreSQL connection string using asyncpg driver.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rental_damage
# Connection pool size (per-worker).
DATABASE_POOL_SIZE=10

# -- Cloudflare R2 (S3-compatible object storage) ----------------------------
# Account ID from the Cloudflare dashboard.
R2_ACCOUNT_ID=your_account_id
# API token credentials with read/write access to the bucket.
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
# Bucket name for photo storage.
R2_BUCKET_NAME=rental-damage-photos
# Public URL prefix for constructing photo URLs at runtime.
# Example: https://pub-abc123.r2.dev
R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# -- Anthropic (Claude API) --------------------------------------------------
# API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key
# Model identifier. Defaults to claude-sonnet-4-20250514.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# -- JWT Authentication -------------------------------------------------------
# Secret key for signing JWT tokens. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION
# Signing algorithm.
JWT_ALGORITHM=HS256
# Token expiration in minutes. Default: 1440 (24 hours).
JWT_EXPIRATION_MINUTES=1440

# -- AI Detection Thresholds --------------------------------------------------
# Minimum confidence score (0-100) for a finding to be included in results.
# Findings below this threshold are discarded.
MIN_CONFIDENCE_THRESHOLD=70
# Maximum number of few-shot examples to include in the prompt.
SIMILAR_CASES_LIMIT=5

# -- Photo Constraints --------------------------------------------------------
# Maximum allowed photo upload size in megabytes.
MAX_PHOTO_SIZE_MB=10
# Comma-separated list of allowed MIME types for photo uploads.
# Note: This is a JSON list in the env var.
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp","image/heic"]

# -- Rate Limiting ------------------------------------------------------------
# Maximum API requests per minute per authenticated user.
API_RATE_LIMIT_PER_MINUTE=60
